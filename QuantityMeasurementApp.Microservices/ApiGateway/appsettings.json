{
  "Jwt": {
    "Key": "my-local-super-secure-jwt-key-1234567890",
    "Issuer": "QuantityMeasurementApp.API",
    "Audience": "QuantityMeasurementApp.API.Users"
  },
  "Services": {
    "AuthService": "http://localhost:5001",
    "QMAService": "http://localhost:5002"
  },
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "authCluster",
        "Match": { "Path": "/api/v1/auth/{**catch-all}" }
      },
      "qma": {
        "ClusterId": "qmaCluster",
        "Match": { "Path": "/api/v1/quantities/{**catch-all}" }
      }
    },
    "Clusters": {
      "authCluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5001/" }
        }
      },
      "qmaCluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5002/" }
        }
      }
    }
  }
}